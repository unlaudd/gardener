# =============================================================================
# 🌱 Огородник — Git Ignore Rules
# =============================================================================
# Repository root: / (project code resides in /gardener/)
#
# This file specifies intentionally untracked files that Git should ignore.
# Patterns are organized by category for maintainability.
#
# Documentation:
#   - Lines starting with # are comments
#   - Patterns match file/directory paths relative to repository root
#   - Trailing / indicates directory-only matches
#   - ! prefix negates a pattern (re-include previously ignored files)
#
# Reference: https://git-scm.com/docs/gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Go Build Artifacts
# -----------------------------------------------------------------------------
# Compiled binaries and build outputs that should not be versioned.
# These are reproducible from source and vary by target platform.

# Main application binary (output of `make build`)
gardener/gardener

# Windows executable variants
gardener/*.exe

# Test coverage reports (generated by `go test -coverprofile`)
gardener/coverage.out

# Go profiler output files (cpu.prof, mem.prof, etc.)
gardener/*.prof

# Temporary test databases created during test execution
gardener/internal/*/test.db

# -----------------------------------------------------------------------------
# Frontend Build Artifacts (Vite/Svelte)
# -----------------------------------------------------------------------------
# Dependencies and compiled assets managed by npm/Vite.
# These are regenerated via `npm install` and `npm run build`.

# Node.js dependencies (installed via `npm install`)
gardener/frontend/node_modules/

# Production build output (generated by `npm run build`)
gardener/frontend/dist/

# SvelteKit framework cache and temporary files
gardener/frontend/.svelte-kit/

# Vite development server cache
gardener/frontend/.vite/

# Frontend build and runtime logs
gardener/frontend/*.log

# Backup files from editor or linting tools
gardener/frontend/eslint.config.js.bak

# -----------------------------------------------------------------------------
# Release and Distribution Artifacts
# -----------------------------------------------------------------------------
# Packaging outputs that are generated by CI/CD or release scripts.
# Source-controlled releases should use Git tags, not binary archives.

# GoReleaser build output directory
gardener/build/

# GoReleaser release artifacts directory
gardener/release/

# Compressed archives (created during release packaging)
*.zip
*.tar.gz

# -----------------------------------------------------------------------------
# Application User Data (CRITICAL: Never Commit)
# -----------------------------------------------------------------------------
# Personal data directories that contain user-specific information.
# These paths must never be tracked to protect privacy and prevent conflicts.

# User data directory (default location: ~/.gardener/)
# Contains: plants.db (SQLite database), photos/ (uploaded images)
.gardener/

# Local development override (if app is run from repo root)
gardener/.gardener/

# -----------------------------------------------------------------------------
# IDE and Editor Configuration
# -----------------------------------------------------------------------------
# Editor-specific settings and temporary files.
# Project-wide editor config should use .editorconfig instead.

# JetBrains IDEs (GoLand, WebStorm, etc.)
.idea/

# Visual Studio Code
.vscode/

# Vim/Neovim swap files
*.swp
*.swo

# Editor backup files (tilde suffix)
*~

# Eclipse project metadata
.project

# Sublime Text workspace files
*.sublime-*

# -----------------------------------------------------------------------------
# Operating System Metadata
# -----------------------------------------------------------------------------
# System-generated files that are not part of the project source.

# macOS Finder metadata
.DS_Store

# Windows Explorer thumbnail cache
Thumbs.db

# Windows folder configuration file
desktop.ini

# Windows Recycle Bin (should not appear in repos, but included for safety)
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Secrets and Environment Configuration
# -----------------------------------------------------------------------------
# Sensitive files that must never be committed to version control.
# Use environment variables or secure secret management for deployment.

# Environment variable files (local development overrides)
*.env
*.local

# Explicitly marked secret files
*.secret

# API credentials or authentication tokens
credentials.json

# -----------------------------------------------------------------------------
# Logs and Temporary Files
# -----------------------------------------------------------------------------
# Runtime artifacts that are ephemeral or machine-specific.

# Application and build log files
*.log
logs/

# Generic temporary directories
tmp/
temp/

# Build tool and package manager caches
.cache/

# -----------------------------------------------------------------------------
# Documentation Drafts (Optional)
# -----------------------------------------------------------------------------
# Working copies of documentation that are not ready for publication.
# Remove these patterns if you want to track all markdown files.

# Editor backup files for markdown documents
*.md~

# Draft documentation directory
docs/drafts/